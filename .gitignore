########################################
# Hermes Project .gitignore
########################################

############################
# OS files
############################
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

############################
# VS Code
############################
.vs/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

############################
# Visual Studio / .NET
############################
bin/
obj/
out/
TestResults/
*.user
*.suo
*.userosscache
*.sln.docstates
*.cache
*.pdb

############################
# Rider / JetBrains
############################
.idea/
*.sln.iml

############################
# Logs
############################
logs/
*.log
*.tlog

############################
# Environment & secrets 
############################
.env
.env.*
appsettings.Development.json
appsettings.Local.json
secrets.json
local.settings.json

# Azure / identity secrets
*.key
*.pem
*.pfx
*.cer

############################
# Node / React 
############################
node_modules/
dist/
build/
.next/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

############################
# Python 
############################
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
pip-wheel-metadata/
*.egg-info/

############################
# Terraform 
############################
.terraform/
*.tfstate
*.tfstate.*
crash.log

############################
# Docker
############################
docker-compose.override.yml

############################
# Test artifacts
############################
coverage/
*.coverage
*.coveragexml

############################
# Temporary files
############################
*.tmp
*.temp
*.swp
*~

############################
# AI / data artifacts 
############################
data/
embeddings/
vector-cache/
rag-cache/